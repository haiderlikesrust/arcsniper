{
  "name": "arcchain-launch-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Watches for Circle Arc L1 mainnet launch, bridges USDC in via CCTP, and executes a preconfigured buy.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "arcbot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bot": "node --import tsx src/index.ts telegram",
    "probe": "node --import tsx src/index.ts probe",
    "claim": "node --import tsx src/index.ts claim",
    "import": "node --import tsx src/index.ts import",
    "export": "node --import tsx src/index.ts export",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "grammy": "^1.45.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

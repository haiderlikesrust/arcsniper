# Copy to .env and fill in. .env is gitignored - never commit it.
# This file holds NO private keys. User wallets are generated by the bot and
# stored encrypted under data/. This file only holds the bot token and,
# optionally, the master passphrase.

# Telegram bot token from @BotFather. Required.
TELEGRAM_BOT_TOKEN=

# Master passphrase that encrypts every user wallet.
# LEAVE UNSET for best security - you'll be prompted at startup and it never
# touches disk. Only set it if you need unattended container restarts, and
# understand that it then lives in this file on the host.
# ARCBOT_MASTER_PASSPHRASE=

# Source-chain RPC (Base). A paid endpoint (Alchemy/QuickNode) is strongly
# recommended for launch day - public endpoints rate-limit when it matters.
BASE_RPC_URL=https://mainnet.base.org

# Optional extra Base RPCs for failover, comma-separated.
BASE_RPC_FALLBACKS=

# Optional extra Arc mainnet RPC candidates to probe, comma-separated.
# The built-in candidate list is in config/networks.json.
ARC_RPC_CANDIDATES=

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
